---
const features = [
  {
    icon: '🤝',
    title: '学生自发维护',
    desc: '由广财学子自发组建和维护，每一篇文章都来自真实的校园经历',
  },
  {
    icon: '📝',
    title: '真实经验分享',
    desc: '拒绝空洞鸡汤，只收录学长学姐亲身走过的路、踩过的坑',
  },
  {
    icon: '📊',
    title: '10万+ 阅读',
    desc: '累计 PV 突破 10 万，已成为广财学子学业规划的重要参考',
  },
  {
    icon: '🌱',
    title: '共建互助社区',
    desc: '每个人都可以贡献自己的经验，让后来者少走弯路',
  },
];
---

<section class="features">
  <div class="container">
    <h2 class="section-title">为什么选择飞跃手册</h2>
    <p class="section-desc">不是官方宣传，不是机构营销——是和你一样的广财人，写下的真实故事</p>
    <div class="features-grid">
      {features.map((f, i) => (
        <div class={`feature-card glass-feature feature-card-${i + 1}`} data-tilt="">
          <span class="feature-icon">{f.icon}</span>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.glass-feature[data-tilt]').forEach(function(card) {
    card.addEventListener('mousemove', function(e) {
      var rect = card.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var y = e.clientY - rect.top;
      var centerX = rect.width / 2;
      var centerY = rect.height / 2;
      var rotateX = ((y - centerY) / centerY) * -8;
      var rotateY = ((x - centerX) / centerX) * 8;
      card.style.transform =
        'perspective(600px) rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg) translateZ(12px) scale(1.02)';
    });
    card.addEventListener('mouseleave', function() {
      card.style.transform = '';
    });
  });
</script>

<style>
  .features {
    padding: 64px 0;
    background-color: var(--bg-alt);
    position: relative;
    overflow: hidden;
  }

  .features::before {
    content: '';
    position: absolute;
    top: -100px;
    left: -100px;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent), transparent 70%);
    opacity: 0.04;
    filter: blur(60px);
    pointer-events: none;
  }

  [data-theme="dark"] .features::before {
    opacity: 0.06;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    perspective: 800px;
  }

  .glass-feature {
    backdrop-filter: blur(12px) saturate(160%);
    -webkit-backdrop-filter: blur(12px) saturate(160%);
    background: linear-gradient(
      135deg,
      rgba(255, 252, 240, 0.60) 0%,
      rgba(255, 248, 228, 0.28) 100%
    );
    border: 1px solid rgba(255, 184, 62, 0.08);
    box-shadow:
      0 4px 24px rgba(127, 99, 21, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.40);
  }

  [data-theme="dark"] .glass-feature {
    background: linear-gradient(
      135deg,
      rgba(139, 124, 246, 0.06) 0%,
      rgba(26, 25, 56, 0.22) 100%
    );
    border: 1px solid rgba(139, 124, 246, 0.08);
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .feature-card {
    padding: 28px 24px;
    border-radius: var(--radius-md);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    will-change: transform;
  }

  .feature-card:hover {
    transform: translateY(-4px) !important;
    box-shadow:
      0 16px 40px rgba(127, 99, 21, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.50),
      0 0 20px rgba(255, 184, 62, 0.06);
    border-color: rgba(255, 184, 62, 0.15);
  }

  [data-theme="dark"] .feature-card:hover {
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 0 20px rgba(139, 124, 246, 0.12);
    border-color: rgba(139, 124, 246, 0.15);
  }

  .feature-icon {
    display: block;
    font-size: 32px;
    margin-bottom: 16px;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.06));
  }

  .feature-title {
    font-size: 17px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .feature-desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  @media (max-width: 960px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
