---

<section class="hero">
  <div class="hero-bg-glow"></div>
  <div class="container">
    <div class="hero-center">
      <div class="hero-badge">🎓 广财学子自己的飞跃手册</div>
      <h1 class="hero-title">减少信息差<br />让每一步都更清晰</h1>
      <p class="hero-desc">
        由广东财经大学学生自发维护的真实经验分享平台。<br />
        转专业、保研、考研、出国留学——学长学姐走过的路，就是你的参考。
      </p>
      <div class="hero-actions">
        <a href="/articles" class="btn btn-primary">开始阅读</a>
        <a href="#categories" class="btn btn-secondary">浏览分类</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-num">10万+</span>
          <span class="hero-stat-label">累计阅读</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">50+</span>
          <span class="hero-stat-label">真实经验</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">6</span>
          <span class="hero-stat-label">覆盖方向</span>
        </div>
      </div>
    </div>

    <div class="hero-cards">
      <a href="/articles?category=考研" class="hero-card glass-card" data-tilt="">
        <span class="hero-card-emoji">📚</span>
        <div class="hero-card-body">
          <h3 class="hero-card-title">考研上岸经验</h3>
          <p class="hero-card-desc">院校选择、备考规划、复试调剂全攻略</p>
        </div>
      </a>
      <a href="/articles?category=出国留学" class="hero-card glass-card" data-tilt="">
        <span class="hero-card-emoji">✈️</span>
        <div class="hero-card-body">
          <h3 class="hero-card-title">留学申请攻略</h3>
          <p class="hero-card-desc">选校定位、语言考试、文书写作时间线</p>
        </div>
      </a>
      <a href="/articles?category=保研" class="hero-card glass-card" data-tilt="">
        <span class="hero-card-emoji">🎓</span>
        <div class="hero-card-body">
          <h3 class="hero-card-title">保研推免指南</h3>
          <p class="hero-card-desc">推免资格、夏令营、材料准备全流程</p>
        </div>
      </a>
      <a href="/articles?category=转专业" class="hero-card glass-card" data-tilt="">
        <span class="hero-card-emoji">🔄</span>
        <div class="hero-card-body">
          <h3 class="hero-card-title">转专业实录</h3>
          <p class="hero-card-desc">跨院系转专业经验、面试准备与心态调整</p>
        </div>
      </a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.hero-card[data-tilt]').forEach(function(card) {
    card.addEventListener('mousemove', function(e) {
      var rect = card.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var y = e.clientY - rect.top;
      var centerX = rect.width / 2;
      var centerY = rect.height / 2;
      var rotateX = ((y - centerY) / centerY) * -6;
      var rotateY = ((x - centerX) / centerX) * 6;
      card.style.transform =
        'perspective(600px) rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg) translateZ(8px) scale(1.02)';
    });
    card.addEventListener('mouseleave', function() {
      card.style.transform = '';
    });
  });
</script>

<style>
  .hero {
    position: relative;
    padding: 80px 0 56px;
    overflow: hidden;
    background-color: var(--bg);
  }

  .hero-bg-glow {
    position: absolute;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 560px;
    height: 360px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
    opacity: 0.06;
    filter: blur(100px);
    pointer-events: none;
    animation: pulseGlow 8s ease-in-out infinite;
  }

  [data-theme="dark"] .hero-bg-glow {
    opacity: 0.08;
  }

  @keyframes pulseGlow {
    0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.06; }
    50% { transform: translateX(-50%) scale(1.15); opacity: 0.10; }
  }

  .hero-center {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 6px 18px;
    font-size: 13px;
    font-weight: 500;
    border-radius: var(--radius-pill);
    background-color: var(--accent-light);
    color: var(--accent);
    margin-bottom: 20px;
  }

  .hero-title {
    font-size: 46px;
    font-weight: 700;
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 16px;
  }

  .hero-desc {
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-secondary);
    margin-bottom: 28px;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 36px;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-stat-num {
    font-size: 24px;
    font-weight: 700;
    color: var(--accent);
  }

  .hero-stat-label {
    font-size: 12px;
    color: var(--text-muted);
  }

  .hero-stat-divider {
    width: 1px;
    height: 28px;
    background-color: var(--border);
  }

  .hero-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 48px;
    perspective: 800px;
  }

  .glass-card {
    backdrop-filter: blur(14px) saturate(170%);
    -webkit-backdrop-filter: blur(14px) saturate(170%);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.55) 0%,
      rgba(255, 248, 230, 0.30) 100%
    );
    border: 1px solid rgba(255, 184, 62, 0.10);
    box-shadow:
      0 4px 24px rgba(127, 99, 21, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.40);
  }

  [data-theme="dark"] .glass-card {
    background: linear-gradient(
      135deg,
      rgba(26, 25, 56, 0.65) 0%,
      rgba(18, 17, 42, 0.45) 100%
    );
    border: 1px solid rgba(139, 124, 246, 0.06);
    box-shadow:
      0 2px 12px rgba(0, 0, 0, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.02);
  }

  .hero-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 22px 20px;
    border-radius: var(--radius-md);
    cursor: default;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    will-change: transform;
  }

  .hero-card:hover {
    transform: translateY(-4px) !important;
    box-shadow:
      0 12px 36px rgba(127, 99, 21, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.45),
      0 0 24px rgba(255, 184, 62, 0.08);
    border-color: rgba(255, 184, 62, 0.18);
    opacity: 1;
  }

  [data-theme="dark"] .hero-card:hover {
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 0 16px rgba(139, 124, 246, 0.06);
    border-color: rgba(139, 124, 246, 0.10);
  }

  .hero-card-emoji {
    font-size: 26px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .hero-card-body {
    min-width: 0;
  }

  .hero-card-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .hero-card-desc {
    font-size: 13px;
    line-height: 1.55;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 960px) {
    .hero-title { font-size: 34px; }
    .hero-cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .hero { padding: 48px 0 32px; }
    .hero-title { font-size: 26px; }
    .hero-stats { gap: 16px; flex-wrap: wrap; }
    .hero-cards { grid-template-columns: 1fr; margin-top: 32px; }
  }
</style>
